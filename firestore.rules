rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 工具函式 ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 使用 memberUids Map 做 O(1) 查詢
    // ⚠️  注意：不能使用 members.hasAny([{userId: uid}]) 做部分物件比對
    //     因為 Firestore Rules 的 hasAny 是完整物件相等比對，永遠不會匹配
    //     正確做法：在 Group 文件中維護一個 memberUids: { [uid]: true } Map
    function isGroupMember(groupId) {
      let group = get(/databases/$(database)/documents/groups/$(groupId));
      return request.auth.uid in group.data.memberUids && group.data.memberUids[request.auth.uid] == true;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function hasOnlyAffectedKeys(newData, oldData, allowedKeys) {
      return newData.diff(oldData).affectedKeys().hasOnly(allowedKeys);
    }

    // ── users ──────────────────────────────────────────────
    match /users/{userId} {
      // 已登入的使用者可查看其他人（顯示頭像、名稱用）
      allow read: if isSignedIn();
      // 只能修改自己的資料
      allow write: if isOwner(userId);
    }

    // ── inviteCodes（公開查詢用，僅存 groupId）──────────────
    match /inviteCodes/{code} {
      // 公開讀取：inviteCode 文件只包含 groupId，無任何敏感資訊
      // 讓未登入使用者也能透過邀請連結預覽群組資訊
      allow read: if true;
      // 已登入使用者可建立邀請碼（建立群組時使用）
      allow create: if isSignedIn()
        && hasOnlyKeys(request.resource.data, ['groupId'])
        && request.resource.data.groupId is string;
      allow update: if false;
      // 僅允許該群組建立者刪除 inviteCode（群組刪除時清理索引）
      allow delete: if isSignedIn()
        && resource.data.groupId is string
        && get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.createdBy == request.auth.uid;
    }

    // ── groups ─────────────────────────────────────────────
    match /groups/{groupId} {
      // 公開讀取單一群組文件：讓未登入使用者也能透過邀請連結預覽群組名稱與成員
      allow get: if true;
      // 列表查詢必須帶 memberUids 過濾條件，確保只回傳自己的群組
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberUids && resource.data.memberUids[request.auth.uid] == true;

      // 任何已登入使用者可建立新群組（建立者欄位必須是自己）
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && hasOnlyKeys(
          request.resource.data,
          ['name', 'coverUrl', 'inviteCode', 'createdBy', 'members', 'memberNameMap', 'memberUids', 'lastExpenseAt', 'createdAt', 'updatedAt']
        );

      allow update: if (
        // ① 現有群組成員更新群組資料（修改名稱、封面、新增/移除成員等）
        // 直接讀取 resource.data 以避免對同一文件重複 get()
        isSignedIn()
        && (request.auth.uid in resource.data.memberUids)
        && resource.data.memberUids[request.auth.uid] == true
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.inviteCode == resource.data.inviteCode
        && hasOnlyAffectedKeys(
          request.resource.data,
          resource.data,
          ['name', 'coverUrl', 'members', 'memberNameMap', 'memberUids', 'lastExpenseAt', 'updatedAt']
        )
      ) || (
        // ② 透過邀請連結自助加入：已登入的非成員將自己加入群組
        //    確保：原本不是成員、加入後成為成員、核心群組屬性不變
        isSignedIn()
        && !(request.auth.uid in resource.data.memberUids)
        && (request.auth.uid in request.resource.data.memberUids)
        && request.resource.data.memberUids[request.auth.uid] == true
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.name == resource.data.name
        && request.resource.data.coverUrl == resource.data.coverUrl
        && hasOnlyAffectedKeys(
          request.resource.data,
          resource.data,
          ['members', 'memberNameMap', 'memberUids', 'updatedAt']
        )
      );

      // 僅允許群組建立者刪除群組
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      // ── expenses 子集合 ─────────────────────────────────
      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.createdBy == request.auth.uid
          && hasOnlyKeys(
            request.resource.data,
            ['title', 'amount', 'paidBy', 'splitMode', 'splits', 'description', 'imageUrl', 'date', 'createdBy', 'repeat', 'expenseId', 'editLog', 'createdAt', 'updatedAt']
          );
        allow update: if isGroupMember(groupId)
          && hasOnlyKeys(
            request.resource.data,
            ['title', 'amount', 'paidBy', 'splitMode', 'splits', 'description', 'imageUrl', 'date', 'createdBy', 'repeat', 'expenseId', 'editLog', 'createdAt', 'updatedAt']
          );
        allow delete: if isGroupMember(groupId);
      }

      // ── settlements 子集合 ───────────────────────────────
      match /settlements/{settlementId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if isGroupMember(groupId)
          && hasOnlyKeys(
            request.resource.data,
            ['settlementId', 'from', 'to', 'amount', 'completed', 'completedBy', 'completedAt', 'createdAt', 'updatedAt']
          );
        // delete has no request.resource.data — check separately
        allow delete: if isGroupMember(groupId);
      }

      // ── activity 子集合 ──────────────────────────────────
      match /activity/{activityId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.actorUid == request.auth.uid
          && hasOnlyKeys(
            request.resource.data,
            ['activityId', 'expenseId', 'actorUid', 'action', 'title', 'amount', 'description', 'timestamp', 'createdAt', 'isSettlement', 'settlementFrom', 'settlementTo']
          );
        allow update, delete: if false;
      }
    }

    // ── personalLedger ─────────────────────────────────────
    // 個人分帳資料僅本人可存取
    match /personalLedger/{userId} {
      allow read, write: if isOwner(userId);

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);

        // 個人帳務記錄（嵌套在聯絡人下）
        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
